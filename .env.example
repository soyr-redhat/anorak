# Anorak Configuration Example
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# Upstream API Configuration
UPSTREAM_API_URL=https://maas.apps.ocp.cloud.rhai-tmm.dev/prelude-maas/kimi-k2-6
UPSTREAM_API_TOKEN=your-api-token-here

# Shard Configuration
SHARD_3_MASTER_SECRET=generate-with-secrets-token-urlsafe-32
SHARD_3_TIME_WINDOW_HOURS=24
SHARD_THRESHOLD=3
SHARD_TOTAL=3

# Handshake Configuration
HANDSHAKE_SHARED_SECRET=demo-shared-secret-key-12345
HANDSHAKE_TIMEOUT_SECONDS=30

# Rotation Configuration
ROTATION_ENABLED=true
ROTATION_TIME_HOURS=24
ROTATION_REQUEST_THRESHOLD=10000
ROTATION_GRACE_PERIOD_MINUTES=5

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Admin API Configuration
ADMIN_API_ENABLED=true
ADMIN_API_KEY=generate-strong-admin-key

# NOTE: Encrypted shards (SHARD_1_ENCRYPTED, SHARD_2_ENCRYPTED, SHARD_3_ENCRYPTED)
# are no longer stored in .env - they are managed in Redis via the rotation API.
# To initialize: POST /admin/rotate with your token
