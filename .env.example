# Anorak Configuration Example
# Copy this file to .env and fill in your values

# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# =============================================================================
# Upstream API Configuration (Provider Agnostic)
# =============================================================================
# OpenAI
# UPSTREAM_API_URL=https://api.openai.com

# Anthropic
# UPSTREAM_API_URL=https://api.anthropic.com

# Local Ollama
# UPSTREAM_API_URL=http://localhost:11434

# Local vLLM
# UPSTREAM_API_URL=http://localhost:8000

UPSTREAM_API_URL=https://api.openai.com

# =============================================================================
# Shard Configuration (Generate with scripts/init_shards.py)
# =============================================================================
# Run: python scripts/init_shards.py --token "your-api-token"
# Then copy the output here

SHARD_1_ENCRYPTED=your-encrypted-shard-1-here
SHARD_2_ENCRYPTED=your-encrypted-shard-2-here
SHARD_ENCRYPTION_KEY=your-encryption-key-here
SHARD_3_MASTER_SECRET=your-master-secret-here

# Time window for shard 3 rotation (hours)
SHARD_3_TIME_WINDOW_HOURS=24

# Shamir parameters (default: 2-of-3)
SHARD_THRESHOLD=2
SHARD_TOTAL=3

# =============================================================================
# Handshake Configuration
# =============================================================================
# Shared secret for HMAC handshake (generate with: openssl rand -hex 32)
HANDSHAKE_SHARED_SECRET=your-handshake-secret-here

# Challenge timeout in seconds
HANDSHAKE_TIMEOUT_SECONDS=30

# =============================================================================
# Rotation Configuration
# =============================================================================
ROTATION_ENABLED=true
ROTATION_TIME_HOURS=24
ROTATION_REQUEST_THRESHOLD=10000
ROTATION_GRACE_PERIOD_MINUTES=5

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Admin API Configuration
# =============================================================================
ADMIN_API_ENABLED=true
# Admin API key (generate with: openssl rand -hex 32)
ADMIN_API_KEY=your-admin-api-key-here
